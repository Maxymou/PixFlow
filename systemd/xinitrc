#!/usr/bin/env bash
set -euo pipefail

export DISPLAY="${DISPLAY:-:0}"

# Disable screensaver / DPMS / screen blanking
xset s off || true
xset -dpms || true
xset s noblank || true

# Start a minimal window manager if available
if command -v openbox-session >/dev/null 2>&1; then
  openbox-session &
fi

# Hide mouse cursor if unclutter exists
if command -v unclutter >/dev/null 2>&1; then
  unclutter -idle 0.5 -root &
fi

CHROMIUM_BIN="$(command -v chromium || command -v chromium-browser || true)"
if [ -z "${CHROMIUM_BIN}" ]; then
  echo "chromium/chromium-browser not found"
  exit 1
fi

exec "${CHROMIUM_BIN}" \
  --kiosk \
  --noerrdialogs \
  --disable-infobars \
  --disable-session-crashed-bubble \
  --disable-features=TranslateUI \
  --autoplay-policy=no-user-gesture-required \
  --check-for-update-interval=31536000 \
  --disable-pinch \
  --overscroll-history-navigation=0 \
  # These flags avoid Chromium GPU-process crashes on Raspberry Pi during HDMI kiosk video playback.
  --disable-gpu \
  --disable-software-rasterizer=false \
  --disable-accelerated-video-decode \
  --disable-gpu-compositing \
  --disable-zero-copy \
  "${PIXFLOW_KIOSK_URL:-http://127.0.0.1:3000/player}"
