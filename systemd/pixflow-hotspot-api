#!/usr/bin/env python3
"""PixFlow hotspot host API.

Listens on 0.0.0.0:4876 for host + Docker bridge traffic and proxies commands to
/usr/local/bin/pixflow-hotspot.
"""

from __future__ import annotations

import json
import ipaddress
import subprocess
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

HOST = "0.0.0.0"
PORT = 4876
HOTSPOT_HELPER = "/usr/local/bin/pixflow-hotspot"
ALLOWED_CLIENT_NETWORKS = (
    ipaddress.ip_network("127.0.0.1/32"),
    ipaddress.ip_network("172.17.0.0/16"),
    ipaddress.ip_network("172.18.0.0/16"),
    ipaddress.ip_network("10.0.0.0/8"),
    ipaddress.ip_network("172.16.0.0/12"),
    ipaddress.ip_network("192.168.0.0/16"),
)


def error_payload(message: str) -> dict:
    return {
        "available": False,
        "enabled": False,
        "error": message,
    }


def extract_json_line(output: str) -> str:
    for line in reversed(output.splitlines()):
        candidate = line.strip()
        if candidate.startswith("{") and candidate.endswith("}"):
            return candidate
    return ""


def is_client_allowed(client_ip: str) -> bool:
    try:
        address = ipaddress.ip_address(client_ip)
    except ValueError:
        return False
    return any(address in network for network in ALLOWED_CLIENT_NETWORKS)


def run_helper(action: str, *args: str) -> tuple[dict, int]:
    try:
        proc = subprocess.run(
            [HOTSPOT_HELPER, action, *args],
            check=False,
            capture_output=True,
            text=True,
            timeout=20,
        )
    except FileNotFoundError:
        return error_payload(f"{HOTSPOT_HELPER} not found"), HTTPStatus.INTERNAL_SERVER_ERROR
    except subprocess.TimeoutExpired:
        return error_payload("hotspot helper timeout"), HTTPStatus.GATEWAY_TIMEOUT
    except Exception as exc:  # noqa: BLE001
        return error_payload(f"helper execution failed: {exc}"), HTTPStatus.INTERNAL_SERVER_ERROR

    stdout = (proc.stdout or "").strip()
    stderr = (proc.stderr or "").strip()
    payload_line = extract_json_line(stdout)

    if not payload_line:
        message = stderr or "helper returned no output"
        return error_payload(message), HTTPStatus.BAD_GATEWAY

    try:
        payload = json.loads(payload_line)
    except json.JSONDecodeError:
        message = f"invalid helper JSON output: {payload_line[:200]}"
        if stderr:
            message = f"{message} (stderr: {stderr[:200]})"
        return error_payload(message), HTTPStatus.BAD_GATEWAY

    if isinstance(payload, dict):
        return payload, HTTPStatus.OK

    return error_payload("helper returned non-object JSON"), HTTPStatus.BAD_GATEWAY


class HotspotHandler(BaseHTTPRequestHandler):
    server_version = "PixFlowHotspotAPI/1.0"

    def _send_json(self, payload: dict, status: int = HTTPStatus.OK) -> None:
        data = json.dumps(payload).encode("utf-8")
        self.send_response(status)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(data)))
        self.end_headers()
        self.wfile.write(data)

    def _read_json_body(self) -> dict:
        length = int(self.headers.get("Content-Length", "0"))
        if length <= 0:
            return {}
        raw = self.rfile.read(length)
        return json.loads(raw.decode("utf-8"))

    def do_GET(self) -> None:  # noqa: N802
        if not is_client_allowed(self.client_address[0]):
            self._send_json(error_payload("forbidden"), HTTPStatus.FORBIDDEN)
            return

        if self.path != "/status":
            self._send_json(error_payload("not found"), HTTPStatus.NOT_FOUND)
            return
        payload, status = run_helper("status")
        self._send_json(payload, status)

    def do_POST(self) -> None:  # noqa: N802
        if not is_client_allowed(self.client_address[0]):
            self._send_json(error_payload("forbidden"), HTTPStatus.FORBIDDEN)
            return

        if self.path == "/enable":
            payload, status = run_helper("enable")
        elif self.path == "/disable":
            payload, status = run_helper("disable")
        elif self.path == "/ensure":
            payload, status = run_helper("ensure")
        elif self.path == "/configure":
            try:
                body = self._read_json_body()
            except json.JSONDecodeError:
                self._send_json(error_payload("invalid JSON body"), HTTPStatus.BAD_REQUEST)
                return
            except Exception as exc:  # noqa: BLE001
                self._send_json(error_payload(f"failed to read request body: {exc}"), HTTPStatus.BAD_REQUEST)
                return

            ssid = body.get("ssid") if isinstance(body, dict) else None
            password = body.get("password") if isinstance(body, dict) else None

            if not isinstance(ssid, str) or not ssid.strip():
                self._send_json(error_payload("ssid is required"), HTTPStatus.BAD_REQUEST)
                return
            if not isinstance(password, str):
                self._send_json(error_payload("password is required"), HTTPStatus.BAD_REQUEST)
                return

            payload, status = run_helper("configure", ssid.strip(), password)
        else:
            self._send_json(error_payload("not found"), HTTPStatus.NOT_FOUND)
            return

        self._send_json(payload, status)

    def log_message(self, fmt: str, *args) -> None:
        return


def main() -> None:
    server = ThreadingHTTPServer((HOST, PORT), HotspotHandler)
    server.serve_forever()


if __name__ == "__main__":
    main()
