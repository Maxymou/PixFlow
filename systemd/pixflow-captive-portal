#!/usr/bin/env python3
"""PixFlow captive portal helper.

Small standalone HTTP server intended to run on Raspberry Pi host and help mobile
OS captive portal checks open PixFlow admin UI.
"""

from __future__ import annotations

import errno
import logging
import os
from http import HTTPStatus
from http.server import BaseHTTPRequestHandler, ThreadingHTTPServer

HOST = "0.0.0.0"
PORT = 80
DEFAULT_ADMIN_URL = "http://10.42.0.1:3000"
ADMIN_URL = os.environ.get("PIXFLOW_ADMIN_URL", DEFAULT_ADMIN_URL).strip() or DEFAULT_ADMIN_URL

HTML_PAGE = """<!doctype html>
<html lang=\"fr\">
<head>
  <meta charset=\"utf-8\" />
  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1\" />
  <title>PixFlow - Portail captif</title>
  <meta http-equiv=\"refresh\" content=\"1; url={admin_url}\" />
  <style>
    body {{ font-family: sans-serif; margin: 0; padding: 2rem; background: #0f172a; color: #e2e8f0; }}
    .card {{ max-width: 480px; margin: 4rem auto; padding: 1.25rem; border-radius: 12px; background: #111827; border: 1px solid #334155; }}
    h1 {{ margin-top: 0; font-size: 1.3rem; }}
    p {{ line-height: 1.4; }}
    a.button {{ display: inline-block; margin-top: 0.5rem; background: #22c55e; color: #052e16; font-weight: 700; text-decoration: none; padding: 0.7rem 1rem; border-radius: 8px; }}
  </style>
</head>
<body>
  <div class=\"card\">
    <h1>PixFlow</h1>
    <p>Connexion détectée au hotspot PixFlow.</p>
    <p>Si la redirection automatique ne se lance pas, utilisez le bouton ci-dessous.</p>
    <a class=\"button\" href=\"{admin_url}\">Ouvrir l’administration PixFlow</a>
  </div>
</body>
</html>
"""


def _html_payload() -> bytes:
    return HTML_PAGE.format(admin_url=ADMIN_URL).encode("utf-8")


class CaptivePortalHandler(BaseHTTPRequestHandler):
    server_version = "PixFlowCaptivePortal/1.0"

    def _send_html(self, status: HTTPStatus = HTTPStatus.OK) -> None:
        payload = _html_payload()
        self.send_response(status)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Cache-Control", "no-store, no-cache, must-revalidate, max-age=0")
        self.send_header("Pragma", "no-cache")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def _send_redirect(self) -> None:
        self.send_response(HTTPStatus.FOUND)
        self.send_header("Location", ADMIN_URL)
        self.send_header("Cache-Control", "no-store, no-cache, must-revalidate, max-age=0")
        self.send_header("Pragma", "no-cache")
        self.end_headers()

    def do_GET(self) -> None:  # noqa: N802
        path = self.path.split("?", 1)[0]

        if path in {"/generate_204", "/gen_204", "/connecttest.txt", "/ncsi.txt"}:
            self._send_redirect()
            return

        if path in {"/hotspot-detect.html", "/library/test/success.html"}:
            self._send_html()
            return

        self._send_html()

    def do_HEAD(self) -> None:  # noqa: N802
        self._send_redirect()

    def log_message(self, fmt: str, *args: object) -> None:
        logging.info("%s - %s", self.client_address[0], fmt % args)


def main() -> int:
    logging.basicConfig(level=logging.INFO, format="[pixflow-captive-portal] %(message)s")
    logging.info("Starting captive portal on %s:%s -> %s", HOST, PORT, ADMIN_URL)

    try:
        server = ThreadingHTTPServer((HOST, PORT), CaptivePortalHandler)
    except OSError as exc:
        if exc.errno == errno.EADDRINUSE:
            logging.error("Port %s is already in use; captive portal cannot start.", PORT)
        else:
            logging.error("Failed to start captive portal: %s", exc)
        return 1

    try:
        server.serve_forever()
    except KeyboardInterrupt:
        logging.info("Stopping captive portal.")
    except Exception as exc:  # noqa: BLE001
        logging.error("Captive portal runtime error: %s", exc)
        return 1
    finally:
        server.server_close()

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
