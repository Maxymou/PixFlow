[Unit]
Description=PixFlow Chromium Kiosk
After=network-online.target docker.service
Wants=network-online.target

[Service]
Type=simple
User=maxymou
WorkingDirectory=/home/maxymou/PixFlow
ExecStart=/usr/bin/startx /home/maxymou/.xinitrc -- :0 -nocursor
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
