[Unit]
Description=PixFlow Debug Host API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=maxymou
WorkingDirectory=/home/maxymou/PixFlow
ExecStart=/usr/bin/node /home/maxymou/PixFlow/scripts/pixflow-debug-api.js
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
